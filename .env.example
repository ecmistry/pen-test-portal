# PenTest Portal — Environment Variables
# Copy to .env and fill in values

# Required for session signing (any non-empty string)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# MySQL connection string (required for full functionality)
# Example: mysql://user:****@localhost:3306/pentest_portal
DATABASE_URL=

# OAuth (required for production login)
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# Optional: First user's OpenID becomes admin
OWNER_OPEN_ID=

# Optional: AI features (Gemini). Set GEMINI_API_KEY for Gemini, or use Forge below.
GEMINI_API_KEY=

# Optional: Custom AI API (overrides GEMINI_API_KEY when both are set)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Dev mode: bypass OAuth, use /api/dev-login to sign in as dev user
# Requires DATABASE_URL. Set both when developing locally without OAuth.
DEV_BYPASS_AUTH=false
VITE_DEV_LOGIN=false

# Admin login: email/password sign-in at /api/admin-login (do not commit .env)
# Set both to enable. Credentials only in .env — never commit.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
